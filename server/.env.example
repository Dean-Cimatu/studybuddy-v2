# MongoDB connection string
# Atlas free tier: https://www.mongodb.com/cloud/atlas
# Local Docker: mongodb://mongo:27017/studybuddy-v2
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/studybuddy-v2

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_output_of_openssl_rand_hex_32
# Get your key at https://console.anthropic.com — server-side ONLY, never expose to client
ANTHROPIC_API_KEY=sk-ant-...
OPEN_AI_KEY=sk-...
PORT=3000

# Google Calendar OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
